# ChainInsight environment variables
# Copy this file to .env and fill in values

# API authentication key (REQUIRED for production)
API_KEY=dev-key-change-me

# Frontend API key for Vite builds / local UI
VITE_API_KEY=dev-key-change-me

# Optional explicit localhost-only fallback for frontend development
# Leave empty unless you intentionally want the browser client to auto-use a dev key on localhost
# VITE_DEV_API_KEY=dev-key-change-me

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database URL (defaults to SQLite)
# DATABASE_URL=sqlite:///chaininsight.db

# Upload limits
MAX_UPLOAD_MB=10

# Rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=30
